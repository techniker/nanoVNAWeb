{
  "name": "nanovnaweb",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --filter './tooling/**' run build",
    "typecheck": "pnpm -r --if-present --parallel typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo && rm -rf node_modules/.vite"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^20.14.0",
    "lefthook": "^1.7.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
